{
    "build": {
        "builder": "NIXPACKS",
        "watchPatterns": [
            "requirements.txt",
            "static/**",
            "app.py",
            "railway.json"
        ]
    },
    "deploy": {
        "startCommand": "bash start.sh",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}